# ── Upstream LLM API ──────────────────────────────────────────────────────
# The LLM provider your proxy forwards clean requests to.
# Compatible with any OpenAI-format API (OpenAI, Anthropic via proxy, Together, etc.)
UPSTREAM_API_BASE=https://api.openai.com
UPSTREAM_API_KEY=your_openai_api_key_here
UPSTREAM_MODEL=gpt-4o-mini

# ── Judge layer model ─────────────────────────────────────────────────────
# Model used for the LLM-as-judge meta-classifier.
# Use the cheapest available model — it only needs to classify, not generate.
JUDGE_MODEL=gpt-4o-mini

# ── Detection thresholds ──────────────────────────────────────────────────
# Score >= BLOCK_THRESHOLD  → HTTP 400 (injection blocked)
# Score >= FLAG_THRESHOLD   → Forward with X-Injection-Warning: true header
# Score < FLAG_THRESHOLD    → Forward cleanly
BLOCK_THRESHOLD=0.75
FLAG_THRESHOLD=0.5

# ── Storage ───────────────────────────────────────────────────────────────
DATABASE_PATH=./proxy.db

# ── Logging ───────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── ML backend ────────────────────────────────────────────────────────────
# Prevent sentence-transformers from loading TensorFlow (avoids TF version conflicts)
USE_TF=false
TRANSFORMERS_NO_ADVISORY_WARNINGS=1
